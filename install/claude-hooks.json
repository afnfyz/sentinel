{
  "Stop": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "echo '{}' && curl -s --max-time 2 -X POST http://localhost:49152/update -H 'Content-Type: application/json' -d '{\"id\":\"claude\",\"name\":\"Claude\",\"status\":\"success\",\"task\":\"Done\"}' > /dev/null &",
          "async": true
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "curl -s --max-time 2 -X POST http://localhost:49152/update -H 'Content-Type: application/json' -d '{\"id\":\"claude\",\"name\":\"Claude\",\"status\":\"thinking\",\"task\":\"Thinking...\"}' > /dev/null && echo '{}'"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/hooks/sentinel-pre-tool.sh"
        }
      ]
    }
  ]
}
